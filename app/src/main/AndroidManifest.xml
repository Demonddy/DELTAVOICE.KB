<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.deltavoice">

    <!-- Required permissions for keyboard functionality -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- IME Service Declaration -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.DeltaVoice">
        
        <!-- Main IME Service -->
        <service
            android:name=".MainKeyboardService"
            android:label="@string/keyboard_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Main Launcher Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Permissions Activity -->
        <activity
            android:name=".PermissionsActivity"
            android:theme="@style/Theme.DeltaVoice"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- Video Recording Activity -->
        <activity
            android:name=".VideoRecordingActivity"
            android:theme="@style/Theme.AppCompat.Light.Dialog"
            android:excludeFromRecents="true"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Voice Process Mode Activity -->
        <activity
            android:name=".VoiceProcessModeActivity"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- Settings Activity -->
        <activity
            android:name=".SettingsActivity"
            android:theme="@style/Theme.DeltaVoice"
            android:exported="false" />

        <!-- Themes Activity -->
        <activity
            android:name=".ThemesActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:exported="false" />

        <!-- Account Activity -->
        <activity
            android:name=".AccountActivity"
            android:theme="@style/Theme.DeltaVoice"
            android:exported="false" />

        <!-- Feature Config Activities -->
        <activity
            android:name=".VideoConfigActivity"
            android:theme="@style/Theme.DeltaVoice"
            android:exported="false" />

        <activity
            android:name=".VoiceConfigActivity"
            android:theme="@style/Theme.DeltaVoice"
            android:exported="false" />

        <activity
            android:name=".AIChatConfigActivity"
            android:theme="@style/Theme.DeltaVoice"
            android:exported="false" />

        <!-- FileProvider for sharing audio files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>

