<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_dark"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <ImageButton
        android:id="@+id/btn_download_voice"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_download"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Download"
        android:tint="@color/voice_color" />

    <ImageButton
        android:id="@+id/btn_preview_voice"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_play"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Preview"
        android:tint="@color/voice_color" />

    <TextView
        android:id="@+id/voice_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:ellipsize="end"
        android:maxLines="1" />

    <TextView
        android:id="@+id/voice_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginStart="8dp" />

    <ImageButton
        android:id="@+id/btn_rename_voice"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_edit"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Rename"
        android:tint="@color/voice_color" />

    <ImageButton
        android:id="@+id/btn_send_voice"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="2dp"
        android:src="@drawable/ic_send"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Send"
        android:tint="@color/voice_color" />
</LinearLayout>
