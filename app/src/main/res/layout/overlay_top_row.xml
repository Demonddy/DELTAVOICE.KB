<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/glass_panel_background"
    android:padding="12dp"
    android:minHeight="60dp">

    <!-- More Options (⋮) - Calculator & Dictionary -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:layout_margin="2dp">
        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_more_vert"
            android:background="@drawable/ai_circle_button"
            android:tint="#FFFFFF"
            android:contentDescription="More options"
            android:padding="8dp" />
    </FrameLayout>

    <!-- Camera/Video Button -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:layout_margin="2dp">
        <ImageButton
            android:id="@+id/btn_camera"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_camera"
            android:background="@drawable/ai_circle_button"
            android:tint="#FFFFFF"
            android:contentDescription="Video Recording"
            android:padding="8dp" />
    </FrameLayout>

    <!-- Home Button -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:layout_margin="2dp">
        <ImageButton
            android:id="@+id/btn_list"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_home"
            android:background="@drawable/ai_circle_button"
            android:tint="#FFFFFF"
            android:contentDescription="Home"
            android:padding="8dp" />
    </FrameLayout>

    <!-- AI Chat Button -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:layout_margin="2dp">
        <ImageButton
            android:id="@+id/btn_text_t"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_ai_chat"
            android:background="@drawable/ai_circle_button"
            android:tint="#FFFFFF"
            android:contentDescription="AI Chat"
            android:padding="8dp" />
    </FrameLayout>

    <!-- KB+ Button (AI Writing Tools) -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:layout_margin="2dp">
        <ImageButton
            android:id="@+id/btn_kb_plus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_kb_plus"
            android:background="@drawable/ai_circle_button"
            android:tint="#FFFFFF"
            android:contentDescription="AI Writing Tools"
            android:padding="8dp" />
    </FrameLayout>

    <!-- Microphone Button -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:layout_margin="2dp">
        <ImageButton
            android:id="@+id/btn_voice"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_mic"
            android:background="@drawable/ai_circle_button"
            android:tint="#FFFFFF"
            android:contentDescription="Voice input"
            android:padding="8dp" />
    </FrameLayout>

    <!-- Clipboard Button -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:layout_margin="2dp">
        <ImageButton
            android:id="@+id/btn_app_grid"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_clipboard"
            android:background="@drawable/ai_circle_button"
            android:tint="#FFFFFF"
            android:contentDescription="Clipboard"
            android:padding="8dp" />
    </FrameLayout>
</LinearLayout>
