<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0E1120"
    android:padding="20dp">

    <!-- Audio Player Bar -->
    <LinearLayout
        android:id="@+id/audio_player_container"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/audio_player_background"
        android:paddingStart="6dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btn_play_recording"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Play recording"
            android:padding="8dp"
            android:tint="#3B82F6" />

        <!-- Audio playback seek bar -->
        <SeekBar
            android:id="@+id/audio_playback_seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#3B82F6"
            android:thumbTint="#3B82F6"
            android:progressBackgroundTint="#2A3140" />

        <TextView
            android:id="@+id/audio_duration_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#9CA3AF"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/title_step"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/voice_mode_title"
        android:textColor="#EDEFF4"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/subtitle_step"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/voice_mode_subtitle"
        android:textColor="#B8BCC7"
        android:textSize="14sp"
        android:paddingBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/card_full_conversion"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/voice_mode_card_selected"
            android:padding="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_lightning"
                android:contentDescription="@string/voice_mode_full" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_mode_full"
                android:textColor="#EDEFF4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_mode_full_desc"
                android:textColor="#B8BCC7"
                android:textSize="11sp"
                android:paddingTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_voice_only"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/voice_mode_card_unselected"
            android:padding="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_mic"
                android:contentDescription="@string/voice_mode_voice_only" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_mode_voice_only"
                android:textColor="#EDEFF4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_mode_voice_only_desc"
                android:textColor="#B8BCC7"
                android:textSize="11sp"
                android:paddingTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_text_only"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/voice_mode_card_unselected"
            android:padding="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_text_t"
                android:contentDescription="@string/voice_mode_text_only" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_mode_text_only"
                android:textColor="#EDEFF4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_mode_text_only_desc"
                android:textColor="#B8BCC7"
                android:textSize="11sp"
                android:paddingTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/voice_mode_pill_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_globe"
                android:contentDescription="@string/voice_mode_language" />

            <Spinner
                android:id="@+id/spinner_language"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:spinnerMode="dropdown"
                android:popupBackground="@drawable/spinner_popup_rounded"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/voice_mode_pill_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_speaker"
                android:contentDescription="@string/voice_mode_voice" />

            <Spinner
                android:id="@+id/spinner_voice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:spinnerMode="dropdown"
                android:popupBackground="@drawable/spinner_popup_rounded"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="18dp">

        <Button
            android:id="@+id/button_send"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Send"
            android:drawableStart="@drawable/ic_send"
            android:drawablePadding="8dp"
            android:background="@drawable/voice_mode_button_green"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"
            android:enabled="false" />

        <Button
            android:id="@+id/button_full_process"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/voice_mode_full_process"
            android:background="@drawable/voice_mode_button_purple"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>

