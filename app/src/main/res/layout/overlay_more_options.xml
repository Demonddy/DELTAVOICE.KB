<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/more_options_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_panel_rounded_28"
    android:padding="16dp"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/btn_more_calculator"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_calculator"
            android:background="@drawable/ai_circle_button"
            android:contentDescription="Calculator"
            android:padding="12dp"
            android:layout_margin="8dp" />

        <ImageButton
            android:id="@+id/btn_more_dictionary"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_dictionary"
            android:background="@drawable/ai_circle_button"
            android:contentDescription="@string/dictionary"
            android:padding="12dp"
            android:layout_margin="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_more_back"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:minWidth="120dp"
        android:text="@string/back_to_keyboard"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/key_dark_background"
        android:layout_marginTop="8dp"
        android:contentDescription="@string/back_to_keyboard" />
</LinearLayout>
