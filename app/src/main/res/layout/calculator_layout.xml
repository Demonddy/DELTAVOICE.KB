<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calculator_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:padding="8dp">

    <!-- Calculator Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2A2A2A"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <!-- Expression -->
        <TextView
            android:id="@+id/calc_expression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="#888888"
            android:gravity="end"
            android:maxLines="1"
            android:ellipsize="start" />

        <!-- Result -->
        <TextView
            android:id="@+id/calc_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="36sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="end"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Row 1: C, (), %, ÷ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/calc_clear"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="C"
            android:textSize="20sp"
            android:textColor="#FF6B6B"
            android:background="@drawable/calc_button_function"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_brackets"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="( )"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_function"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_percent"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="%"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_function"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_divide"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="÷"
            android:textSize="24sp"
            android:textColor="#A78BFA"
            android:background="@drawable/calc_button_operator"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- Row 2: 7, 8, 9, × -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/calc_7"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="7"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_8"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="8"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_9"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="9"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_multiply"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="×"
            android:textSize="24sp"
            android:textColor="#A78BFA"
            android:background="@drawable/calc_button_operator"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- Row 3: 4, 5, 6, - -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/calc_4"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="4"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_5"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="5"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_6"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="6"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_minus"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="−"
            android:textSize="24sp"
            android:textColor="#A78BFA"
            android:background="@drawable/calc_button_operator"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- Row 4: 1, 2, 3, + -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/calc_1"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="1"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_2"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="2"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_3"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="3"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_plus"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="+"
            android:textSize="24sp"
            android:textColor="#A78BFA"
            android:background="@drawable/calc_button_operator"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- Row 5: ⌨, 0, ., = -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/calc_keyboard"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="⌨"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_function"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_0"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="0"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_decimal"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="."
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_number"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/calc_equals"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="="
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_equals"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- Insert Result and Delete Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/calc_insert"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:layout_marginEnd="6dp"
            android:text="Insert Result"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_insert"
            android:textAllCaps="false"
            android:minHeight="48dp" />

        <Button
            android:id="@+id/calc_delete"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⌫ Del"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/calc_button_function"
            android:contentDescription="Delete last character"
            android:textAllCaps="false"
            android:minHeight="48dp" />

    </LinearLayout>

</LinearLayout>
