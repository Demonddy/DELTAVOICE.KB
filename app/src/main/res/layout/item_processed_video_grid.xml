<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical"
    android:background="@drawable/bg_card_dark"
    android:padding="10dp"
    android:layout_margin="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/grid_media_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_video"
            android:tint="@color/video_color"
            android:contentDescription="Media" />

        <TextView
            android:id="@+id/grid_video_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="2" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_download_video"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_download"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Download"
            android:tint="@color/video_color" />

        <ImageButton
            android:id="@+id/btn_preview_video"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Preview"
            android:tint="@color/video_color" />

        <ImageButton
            android:id="@+id/btn_rename_video"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_edit"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rename"
            android:tint="@color/video_color" />

        <ImageButton
            android:id="@+id/btn_send_video"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_send"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Send"
            android:tint="@color/video_color" />
    </LinearLayout>

</LinearLayout>
