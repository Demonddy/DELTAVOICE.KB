<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_root_background"
    android:padding="4dp">

    <!-- Liquid Glass Top Bar: more_vert, videocam, home, AI, KB, mic, clipboard -->
    <FrameLayout
        android:id="@+id/top_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/glass_panel_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:minHeight="60dp">

        <LinearLayout
            android:id="@+id/ai_features_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">

        <!-- More Options (⋮) - Calculator & Dictionary hidden under -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="2dp">
            <ImageButton
                android:id="@+id/btn_more"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_more_vert"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:contentDescription="More options"
                android:padding="8dp" />
        </FrameLayout>

        <!-- Camera/Video Button -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="2dp">
            <ImageButton
                android:id="@+id/btn_camera"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_camera"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:contentDescription="Video Recording"
                android:padding="8dp" />
        </FrameLayout>

        <!-- Home Button -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="2dp">
            <ImageButton
                android:id="@+id/btn_list"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_home"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:contentDescription="Home"
                android:padding="8dp" />
        </FrameLayout>

        <!-- AI Chat Button -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="2dp">
            <ImageButton
                android:id="@+id/btn_text_t"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_ai_chat"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:contentDescription="AI Chat"
                android:padding="8dp" />
        </FrameLayout>

        <!-- KB+ Button (AI Writing Tools) -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="2dp">
            <ImageButton
                android:id="@+id/btn_kb_plus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_kb_plus"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:contentDescription="AI Writing Tools"
                android:padding="8dp" />
        </FrameLayout>

        <!-- Microphone Button -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="2dp">
            <ImageButton
                android:id="@+id/btn_voice"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:contentDescription="@string/voice_input"
                android:padding="8dp" />
        </FrameLayout>

        <!-- Clipboard Button -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_margin="2dp">
            <ImageButton
                android:id="@+id/btn_app_grid"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_clipboard"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:contentDescription="Clipboard"
                android:padding="8dp" />
        </FrameLayout>
        </LinearLayout>

        <!-- Predictive text suggestions (replaces icons when typing) -->
        <LinearLayout
            android:id="@+id/predictions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:padding="4dp"
            android:minHeight="48dp">

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/predictions_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />
            </HorizontalScrollView>

            <!-- Voice and return buttons (always visible when predictions shown) -->
            <ImageButton
                android:id="@+id/predictions_voice_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_mic"
                android:background="@drawable/ai_circle_button"
                android:contentDescription="Voice input"
                android:layout_marginStart="4dp"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/predictions_return_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:contentDescription="Return to icons"
                android:layout_marginStart="4dp"
                android:padding="8dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- AI Features Container (Language Selector - Hidden by default) -->
    <LinearLayout
        android:id="@+id/ai_features_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Language Selector Container -->
        <LinearLayout
            android:id="@+id/language_selector_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="4dp">
        </LinearLayout>
    </LinearLayout>

    <!-- Full Emoji Picker (Hidden by default) -->
    <include
        android:id="@+id/emoji_picker_include"
        layout="@layout/emoji_picker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- Calculator (Hidden by default) -->
    <include
        android:id="@+id/calculator_include"
        layout="@layout/calculator_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- Dictionary (Hidden by default) -->
    <include
        android:id="@+id/dictionary_include"
        layout="@layout/dictionary_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- Voice Recording UI (Step 1) - Shows when recording -->
    <LinearLayout
        android:id="@+id/voice_recording_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0A0A"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Header with back button, title, timer, and upload -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btn_recording_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/voice_input"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />

            <!-- Live recording timer -->
            <TextView
                android:id="@+id/recording_timer_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="14sp"
                android:textColor="#66FFFFFF"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_voice_upload"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_upload"
                android:background="@drawable/ai_circle_button"
                android:contentDescription="Upload audio file"
                android:padding="8dp"
                android:tint="#FFFFFF"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Mic button with rings -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_gravity="center">

            <!-- Outer ring -->
            <View
                android:id="@+id/recording_ring_outer"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/recording_ring_outer" />

            <!-- Middle ring -->
            <View
                android:id="@+id/recording_ring_middle"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/recording_ring_middle" />

            <!-- Mic button -->
            <ImageButton
                android:id="@+id/btn_recording_mic"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                android:background="@drawable/recording_mic_button"
                android:tint="#FFFFFF"
                android:padding="20dp"
                android:contentDescription="Tap to pause" />
        </FrameLayout>

        <!-- Status text -->
        <TextView
            android:id="@+id/recording_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tap_to_record"
            android:textSize="16sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:paddingTop="16dp" />
    </LinearLayout>

    <include layout="@layout/voice_processing_step2" />

    <!-- Video Recording Container - Hidden by default -->
    <FrameLayout
        android:id="@+id/video_recording_container"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="#0A0A0A"
        android:visibility="gone">

        <!-- Camera Preview -->
        <TextureView
            android:id="@+id/camera_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Header Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="#80000000"
            android:layout_gravity="top">

            <ImageButton
                android:id="@+id/btn_video_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/video_recording"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />

            <TextView
                android:id="@+id/video_recording_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="14sp"
                android:textColor="#FF5252"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Recording Controls Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:layout_gravity="bottom"
            android:background="#80000000">

            <TextView
                android:id="@+id/video_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_start_recording"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="12dp" />

            <ImageButton
                android:id="@+id/btn_video_record"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_camera"
                android:background="@drawable/recording_mic_button"
                android:tint="#FFFFFF"
                android:padding="16dp"
                android:contentDescription="Record Video" />
        </LinearLayout>

        <!-- Upload Button - top right, for video/image from gallery -->
        <ImageButton
            android:id="@+id/btn_video_upload"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="56dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_upload"
            android:background="@drawable/ai_circle_button"
            android:contentDescription="Upload video or image"
            android:padding="10dp"
            android:tint="#FFFFFF" />

        <!-- Switch Camera Button -->
        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_margin="60dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Switch Camera" />
    </FrameLayout>

    <!-- Video Preview & Processing Container - Hidden by default -->
    <ScrollView
        android:id="@+id/video_preview_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:background="#111521"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Header with send + close button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/preview_process_video"
                android:textSize="16sp"
                android:textColor="#E5E7EB"
                android:textStyle="bold" />

            <!-- Send original video immediately (no processing) -->
            <ImageButton
                android:id="@+id/btn_video_send_raw"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_send"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Send original video"
                android:tint="@color/gradient_middle" />

            <ImageButton
                android:id="@+id/btn_video_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:tint="#9CA3AF" />
        </LinearLayout>

        <!-- Video Player - play button overlays center, compact for clarity -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:minHeight="140dp"
            android:background="#1A1F2E"
            android:layout_marginBottom="12dp">

            <VideoView
                android:id="@+id/video_player"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <ImageButton
                android:id="@+id/btn_play_video"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:padding="10dp"
                android:contentDescription="Play Video" />

            <TextView
                android:id="@+id/video_duration_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:padding="4dp"
                android:background="#80000000"
                android:text="0:00"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </FrameLayout>

        <!-- Processing Options Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/processing_options"
            android:textSize="13sp"
            android:textColor="#A3A3A3"
            android:paddingBottom="8dp" />

        <!-- Language and Voice Selectors - clear pill-style buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Language Spinner Container -->
            <LinearLayout
                android:id="@+id/video_language_spinner_container"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/voice_mode_pill_highlighted"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_globe"
                    android:tint="@color/accent" />

                <Spinner
                    android:id="@+id/video_spinner_language"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#2A3140"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Voice Spinner Container -->
            <LinearLayout
                android:id="@+id/video_voice_spinner_container"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/voice_mode_pill_highlighted"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_speaker"
                    android:tint="@color/accent" />

                <Spinner
                    android:id="@+id/video_spinner_voice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#2A3140"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Process Button -->
        <Button
            android:id="@+id/btn_process_video"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/process_video"
            android:drawableStart="@drawable/ic_ai_mode"
            android:drawablePadding="10dp"
            android:background="@drawable/voice_mode_button_purple"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        </LinearLayout>
    </ScrollView>

    <!-- AI Chat Container - Hidden by default -->
    <LinearLayout
        android:id="@+id/ai_chat_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111521"
        android:visibility="gone">

        <!-- Chat Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="#1A1F2E">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_ai_mode"
                android:tint="#A78BFA" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ai_chat_title"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="10dp" />

            <ImageButton
                android:id="@+id/ai_chat_close_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:tint="#9CA3AF" />
        </LinearLayout>

        <!-- Chat Messages Area - compact height to leave room for keyboard -->
        <ScrollView
            android:id="@+id/ai_chat_scroll"
            android:layout_width="match_parent"
            android:layout_height="@dimen/ai_chat_messages_height"
            android:fillViewport="true"
            android:background="#111521">

            <LinearLayout
                android:id="@+id/ai_chat_messages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Welcome Message -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ai_chat_bubble_ai"
                        android:padding="12dp"
                        android:layout_marginEnd="48dp">

                        <TextView
                            android:id="@+id/ai_welcome_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ai_chat_welcome"
                            android:textColor="#E5E7EB"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Input Area with Mini Keyboard -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1F2E"
            android:padding="8dp">

            <!-- Input Bar - expands vertically for multi-line text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="44dp"
                android:orientation="horizontal"
                android:background="@drawable/ai_chat_input_background"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/ai_chat_input_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Type your message..."
                    android:textColorHint="#6B7280"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:maxLines="8"
                    android:lineSpacingMultiplier="1.2" />

                <ImageButton
                    android:id="@+id/ai_chat_clear_btn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Clear"
                    android:tint="#6B7280"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/ai_chat_send_btn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_send"
                    android:background="@drawable/ai_chat_send_button"
                    android:contentDescription="Send"
                    android:tint="#FFFFFF"
                    android:padding="8dp" />
            </LinearLayout>

            <!-- AI Chat predictive suggestions -->
            <HorizontalScrollView
                android:id="@+id/ai_chat_suggestions_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:fillViewport="true"
                android:visibility="gone"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:id="@+id/ai_chat_suggestions_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:minHeight="40dp" />
            </HorizontalScrollView>

            <!-- Mini Keyboard Rows - scrollable when space is limited -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="220dp"
                android:scrollbars="none"
                android:fillViewport="true"
                android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <LinearLayout
                android:id="@+id/ai_chat_row0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="2dp"
                android:paddingEnd="2dp" />

            <LinearLayout
                android:id="@+id/ai_chat_row1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="2dp"
                android:paddingEnd="2dp" />

            <LinearLayout
                android:id="@+id/ai_chat_row2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="6dp"
                android:paddingEnd="6dp" />

            <LinearLayout
                android:id="@+id/ai_chat_row3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            </LinearLayout>
            </ScrollView>

            <!-- Bottom Row: Space and Special Keys -->
            <LinearLayout
                android:id="@+id/ai_chat_mini_keyboard_bottom_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="2dp">

                <Button
                    android:id="@+id/ai_chat_key_globe"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/ai_chat_bottom_row_height"
                    android:layout_weight="1"
                    android:text="🌐"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/dict_key_special"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/ai_chat_key_emoji"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/ai_chat_bottom_row_height"
                    android:layout_weight="1"
                    android:text="\uD83D\uDE00"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/dict_key_special"
                    android:layout_marginEnd="2dp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/ai_chat_key_space"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/ai_chat_bottom_row_height"
                    android:layout_weight="3"
                    android:text="space"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:background="@drawable/dict_key_background"
                    android:layout_marginEnd="2dp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/ai_chat_key_send"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/ai_chat_bottom_row_height"
                    android:layout_weight="1.2"
                    android:text="@string/send"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/voice_mode_button_purple"
                    android:layout_marginEnd="2dp"
                    android:textAllCaps="false" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- AI Writing Tools Container (Hidden by default) -->
    <include
        android:id="@+id/ai_writing_tools_include"
        layout="@layout/ai_writing_tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- More Options Container (Calculator, Dictionary - replaces keyboard when three-dots tapped) -->
    <LinearLayout
        android:id="@+id/more_options_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F0F10"
        android:padding="16dp"
        android:visibility="gone"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp">

            <!-- Calculator (hidden from main row) -->
            <ImageButton
                android:id="@+id/btn_more_calculator"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_calculator"
                android:background="@drawable/ai_circle_button"
                android:contentDescription="Calculator"
                android:padding="12dp"
                android:layout_margin="8dp" />

            <!-- Dictionary (hidden from main row) -->
            <ImageButton
                android:id="@+id/btn_more_dictionary"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_dictionary"
                android:background="@drawable/ai_circle_button"
                android:contentDescription="Dictionary"
                android:padding="12dp"
                android:layout_margin="8dp" />
        </LinearLayout>

        <!-- Back to keyboard -->
        <Button
            android:id="@+id/btn_more_back"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="120dp"
            android:text="@string/back_to_keyboard"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/key_dark_background"
            android:layout_marginTop="8dp"
            android:contentDescription="Back to keyboard" />
    </LinearLayout>

    <!-- Liquid Glass Keyboard Panel - Gboard-style: minimal padding for larger keys -->
    <FrameLayout
        android:id="@+id/keyboard_panel_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_keyboard_panel_background"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/keyboard_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp">

        <!-- Numbers Row: 1 2 3 4 5 6 7 8 9 0 -->
        <LinearLayout
            android:id="@+id/row_numbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="0dp">
        </LinearLayout>

        <!-- First Letter Row: Q W E R T Y U I O P -->
        <LinearLayout
            android:id="@+id/row_qwerty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="0dp">
        </LinearLayout>

        <!-- Second Letter Row: A S D F G H J K L -->
        <LinearLayout
            android:id="@+id/row_asdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="0dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">
        </LinearLayout>

        <!-- Third Letter Row: Z X C V B N M -->
        <LinearLayout
            android:id="@+id/row_zxcv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="0dp">
        </LinearLayout>

        <!-- Bottom Row -->
        <LinearLayout
            android:id="@+id/row_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="0dp">
        </LinearLayout>

    </LinearLayout>

    </FrameLayout>

</LinearLayout>
