<?xml version="1.0" encoding="utf-8"?>
<!-- Extracted from keyboard_layout.xml — same IDs as ai_chat_container -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_chat_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111521">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#1A1F2E">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_ai_mode"
            android:tint="#A78BFA" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ai_chat_title"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp" />

        <ImageButton
            android:id="@+id/ai_chat_close_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            android:tint="#9CA3AF" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/ai_chat_scroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/ai_chat_messages_height"
        android:fillViewport="true"
        android:background="#111521">

        <LinearLayout
            android:id="@+id/ai_chat_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ai_chat_bubble_ai"
                    android:padding="12dp"
                    android:layout_marginEnd="48dp">

                    <TextView
                        android:id="@+id/ai_welcome_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_chat_welcome"
                        android:textColor="#E5E7EB"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1F2E"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:orientation="horizontal"
            android:background="@drawable/ai_chat_input_background"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/ai_chat_input_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Type your message..."
                android:textColorHint="#6B7280"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:maxLines="8"
                android:lineSpacingMultiplier="1.2" />

            <ImageButton
                android:id="@+id/ai_chat_clear_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear"
                android:tint="#6B7280"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/ai_chat_send_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_send"
                android:background="@drawable/ai_chat_send_button"
                android:contentDescription="Send"
                android:tint="#FFFFFF"
                android:padding="8dp" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/ai_chat_suggestions_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="true"
            android:visibility="gone"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:id="@+id/ai_chat_suggestions_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="40dp" />
        </HorizontalScrollView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <ScrollView
            android:id="@+id/ai_chat_mini_keyboard_letter_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="220dp"
            android:scrollbars="none"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/ai_chat_row0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp" />

                <LinearLayout
                    android:id="@+id/ai_chat_row1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp" />

                <LinearLayout
                    android:id="@+id/ai_chat_row2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp" />

                <LinearLayout
                    android:id="@+id/ai_chat_row3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

            </LinearLayout>
        </ScrollView>

        <include
            layout="@layout/ai_chat_inline_emoji_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/ai_chat_mini_keyboard_bottom_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="2dp">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/ai_chat_key_keyboard"
                android:layout_width="0dp"
                android:layout_height="@dimen/ai_chat_bottom_row_height"
                android:layout_weight="1"
                android:src="@drawable/ic_keyboard"
                app:tint="#A78BFA"
                android:background="@drawable/dict_key_special"
                android:contentDescription="@string/content_desc_ai_chat_keyboard"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp" />

            <Button
                android:id="@+id/ai_chat_key_mode"
                android:layout_width="0dp"
                android:layout_height="@dimen/ai_chat_bottom_row_height"
                android:layout_weight="1"
                android:text="@string/numbers_mode_symbols"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:background="@drawable/dict_key_special"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/ai_chat_key_globe"
                android:layout_width="0dp"
                android:layout_height="@dimen/ai_chat_bottom_row_height"
                android:layout_weight="1"
                android:src="@drawable/ic_globe"
                app:tint="@android:color/white"
                android:background="@drawable/dict_key_special"
                android:contentDescription="@string/content_desc_ai_chat_language"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/ai_chat_key_emoji"
                android:layout_width="0dp"
                android:layout_height="@dimen/ai_chat_bottom_row_height"
                android:layout_weight="1"
                android:src="@drawable/ic_emoji_smileys"
                app:tint="@android:color/white"
                android:background="@drawable/dict_key_special"
                android:contentDescription="@string/content_desc_ai_chat_emoji"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="2dp" />

            <Button
                android:id="@+id/ai_chat_key_space"
                android:layout_width="0dp"
                android:layout_height="@dimen/ai_chat_bottom_row_height"
                android:layout_weight="3"
                android:text="space"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:background="@drawable/dict_key_background"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/ai_chat_key_send"
                android:layout_width="0dp"
                android:layout_height="@dimen/ai_chat_bottom_row_height"
                android:layout_weight="1.2"
                android:text="@string/send"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/voice_mode_button_purple"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
