<?xml version="1.0" encoding="utf-8"?>
<!-- Extracted from keyboard_layout.xml — same IDs as voice_recording_container -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/voice_recording_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btn_recording_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/voice_input"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/recording_timer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="14sp"
            android:textColor="#66FFFFFF"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btn_voice_upload"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_upload"
            android:background="@drawable/ai_circle_button"
            android:contentDescription="Upload audio file"
            android:padding="8dp"
            android:tint="#FFFFFF"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="center">

        <View
            android:id="@+id/recording_ring_outer"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:background="@drawable/recording_ring_outer" />

        <View
            android:id="@+id/recording_ring_middle"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/recording_ring_middle" />

        <ImageButton
            android:id="@+id/btn_recording_mic"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_mic"
            android:background="@drawable/recording_mic_button"
            android:tint="#FFFFFF"
            android:padding="20dp"
            android:contentDescription="Tap to pause" />
    </FrameLayout>

    <TextView
        android:id="@+id/recording_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tap_to_record"
        android:textSize="16sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:paddingTop="16dp" />
</LinearLayout>
