<?xml version="1.0" encoding="utf-8"?>
<!-- Video Preview & Processing Container - Hidden by default -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/video_preview_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="#111521"
    android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Header with send + close button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/preview_process_video"
                android:textSize="16sp"
                android:textColor="#E5E7EB"
                android:textStyle="bold" />

            <!-- Send original video immediately (no processing) -->
            <ImageButton
                android:id="@+id/btn_video_send_raw"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_send"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Send original video"
                android:tint="@color/gradient_middle" />

            <ImageButton
                android:id="@+id/btn_video_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:tint="#9CA3AF" />
        </LinearLayout>

        <!-- Video Player - play button overlays center, compact for clarity -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:minHeight="140dp"
            android:background="#1A1F2E"
            android:layout_marginBottom="12dp">

            <VideoView
                android:id="@+id/video_player"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <ImageButton
                android:id="@+id/btn_play_video"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:background="@drawable/ai_circle_button"
                android:tint="#FFFFFF"
                android:padding="10dp"
                android:contentDescription="Play Video" />

            <TextView
                android:id="@+id/video_duration_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:padding="4dp"
                android:background="#80000000"
                android:text="0:00"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </FrameLayout>

        <!-- Processing Options Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/processing_options"
            android:textSize="13sp"
            android:textColor="#A3A3A3"
            android:paddingBottom="8dp" />

        <!-- Language and Voice Selectors - clear pill-style buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Language Spinner Container -->
            <LinearLayout
                android:id="@+id/video_language_spinner_container"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/voice_mode_pill_highlighted"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_globe"
                    android:tint="@color/accent" />

                <Spinner
                    android:id="@+id/video_spinner_language"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#2A3140"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Voice Spinner Container -->
            <LinearLayout
                android:id="@+id/video_voice_spinner_container"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/voice_mode_pill_highlighted"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_speaker"
                    android:tint="@color/accent" />

                <Spinner
                    android:id="@+id/video_spinner_voice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#2A3140"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Process Button -->
        <Button
            android:id="@+id/btn_process_video"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/process_video"
            android:drawableStart="@drawable/ic_ai_mode"
            android:drawablePadding="10dp"
            android:background="@drawable/voice_mode_button_purple"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        </LinearLayout>
    </ScrollView>