<?xml version="1.0" encoding="utf-8"?>
<!-- kB+ writing tools + AI chat in one overlay (tool runs switch to chat without new activity) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_kb_plus_host"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111521">

    <FrameLayout
        android:id="@+id/overlay_ai_writing_slot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <FrameLayout
        android:id="@+id/overlay_ai_chat_slot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />
</LinearLayout>
