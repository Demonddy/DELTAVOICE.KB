<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111827"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_dictionary"
            android:tint="#A78BFA"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dictionary"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/dict_close_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#9CA3AF"
            android:contentDescription="Close" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/dict_search_edit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Type a word to search..."
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#6B7280"
            android:background="@drawable/dict_search_background"
            android:padding="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <Button
            android:id="@+id/dict_search_btn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="Search"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/dict_search_button"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textAllCaps="false" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/dict_results_background"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dict_word_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="20sp"
                android:textColor="#A78BFA"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_phonetic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#9CA3AF"
                android:fontFamily="monospace"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_part_of_speech"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#10B981"
                android:textStyle="italic"
                android:background="@drawable/dict_pos_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_definition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"
                android:textColor="#E5E7EB"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_example"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#9CA3AF"
                android:textStyle="italic"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Type a word and tap Search to see its definition"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:gravity="center" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/dict_copy_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="Copy to Clipboard"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/voice_mode_button_purple"
        android:textAllCaps="false" />
</LinearLayout>
