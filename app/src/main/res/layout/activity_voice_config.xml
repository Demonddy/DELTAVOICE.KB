<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice input &amp; cloning"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Workflow modes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Processing mode"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/card_full"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/voice_mode_card_selected"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_lightning"
                    android:contentDescription="Full conversion"
                    android:tint="@color/voice_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voice_mode_full"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voice_mode_full_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:paddingTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_voice_only"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/voice_mode_card_unselected"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="Voice only"
                    android:tint="@color/voice_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voice_mode_voice_only"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voice_mode_voice_only_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:paddingTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_text_only"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/voice_mode_card_unselected"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_text_t"
                    android:contentDescription="Text only"
                    android:tint="@color/voice_color" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voice_mode_text_only"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voice_mode_text_only_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:paddingTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Language & Voice -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/voice_mode_pill_highlighted"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_globe"
                    android:tint="@color/voice_color" />

                <Spinner
                    android:id="@+id/spinner_language"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#2A3140" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/voice_mode_pill_highlighted"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_speaker"
                    android:tint="@color/voice_color" />

                <Spinner
                    android:id="@+id/spinner_voice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#2A3140" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Record and process voice on this page."
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <!-- Upload and Record buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_upload_voice"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="  Upload"
                android:drawableStart="@drawable/ic_upload"
                android:drawablePadding="10dp"
                android:background="@drawable/voice_mode_button_purple"
                android:textColor="@color/text_primary"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btn_record_voice"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="  Record"
                android:drawableStart="@drawable/ic_mic"
                android:drawablePadding="10dp"
                android:background="@drawable/voice_mode_button_purple"
                android:textColor="@color/text_primary"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Recording / Processing section (visible after recording) -->
        <LinearLayout
            android:id="@+id/voice_recording_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="12dp"
                android:layout_marginBottom="12dp">

                <ImageButton
                    android:id="@+id/btn_play_recording"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_play"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Play"
                    android:tint="@color/voice_color" />

                <TextView
                    android:id="@+id/recording_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recording ready"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:id="@+id/audio_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_process_voice"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="  Process"
                android:drawableStart="@drawable/ic_ai_mode"
                android:drawablePadding="8dp"
                android:background="@drawable/voice_mode_button_purple"
                android:textColor="@color/text_primary"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/processed_voices_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Processed voices"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/processed_voices_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
