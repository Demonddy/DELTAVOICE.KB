<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dictionary_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111827"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_dictionary"
            android:tint="#A78BFA"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dictionary"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/dict_source_lang"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="English"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/dict_spinner_background"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:layout_marginEnd="4dp"
                android:textAllCaps="false" />

            <ImageButton
                android:id="@+id/dict_swap_btn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_swap"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Swap languages"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/dict_target_lang"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="العربية"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/dict_spinner_background"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:textAllCaps="false" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/dict_close_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#9CA3AF"
            android:contentDescription="Close"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:background="@drawable/dict_search_background"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:layout_marginBottom="6dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_menu_search"
            android:tint="#6B7280"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/dict_search_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:hint="Type a word to search..."
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#6B7280"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/dict_clear_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_input_delete"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#6B7280"
            android:contentDescription="Clear"
            android:visibility="gone" />

        <Button
            android:id="@+id/dict_search_btn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Search"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/dict_search_button"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textAllCaps="false" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/dict_suggestions_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:fillViewport="true"
        android:visibility="gone"
        android:layout_marginBottom="6dp">

        <LinearLayout
            android:id="@+id/dict_suggestions_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="36dp" />
    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="6dp">

        <ScrollView
            android:id="@+id/dict_results_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/dict_results_background"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/dict_results_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dict_word_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="17sp"
                android:textColor="#A78BFA"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_phonetic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:fontFamily="monospace"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_part_of_speech"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="#10B981"
                android:textStyle="italic"
                android:background="@drawable/dict_pos_badge"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_definition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#E5E7EB"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_example"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:textStyle="italic"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/dict_placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Type a word and tap Search to see its definition"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:gravity="center" />
            </LinearLayout>
        </ScrollView>

        <com.deltavoice.ui.ShimmerView
            android:id="@+id/dict_shimmer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A1A"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="6dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/dict_mini_keyboard_letter_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/dict_row0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center" />

                <LinearLayout
                    android:id="@+id/dict_row1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center" />

                <LinearLayout
                    android:id="@+id/dict_row2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <LinearLayout
                    android:id="@+id/dict_row3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="4dp" />
            </LinearLayout>

            <include
                layout="@layout/dict_inline_emoji_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/dict_row4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="2dp">

            <Button
                android:id="@+id/dict_key_mode"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/numbers_mode_symbols"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:background="@drawable/dict_key_special"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/dict_key_symbols"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="⌨"
                android:textSize="16sp"
                android:textColor="#A78BFA"
                android:background="@drawable/dict_key_special"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/dict_key_globe"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="🌐"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/dict_key_special"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/dict_key_emoji"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="☺"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/dict_key_special"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/dict_key_space"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="3.5"
                android:text="Space"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/dict_key_background"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/dict_key_dot"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.8"
                android:text="."
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/dict_key_special"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/dict_key_search"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="⌕"
                android:textSize="18sp"
                android:textColor="#4A9EFF"
                android:background="@drawable/dict_key_special"
                android:layout_marginEnd="2dp"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
