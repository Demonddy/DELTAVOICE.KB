<?xml version="1.0" encoding="utf-8"?>
<!-- Floating overlay landscape: text field + 3-column tools -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ai_writing_tools_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111521"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:layout_marginBottom="4dp">
        <ImageButton
            android:id="@+id/ai_tools_close_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_close_ai_tools"
            android:tint="#9CA3AF" />
    </LinearLayout>

    <EditText
        android:id="@+id/ai_writing_tools_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:minLines="3"
        android:maxLines="6"
        android:gravity="top|start"
        android:padding="10dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/ai_chat_input_background"
        android:hint="@string/ai_writing_tools_input_hint"
        android:textColorHint="#6B7280"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:inputType="textMultiLine|textCapSentences"
        android:importantForAutofill="no" />

    <include layout="@layout/ai_writing_tools_content" />

</LinearLayout>
