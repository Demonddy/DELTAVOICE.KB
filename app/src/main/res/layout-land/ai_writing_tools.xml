<?xml version="1.0" encoding="utf-8"?>
<!-- IME landscape: tool grid only, no text field -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ai_writing_tools_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111521"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:layout_marginBottom="4dp">
        <ImageButton
            android:id="@+id/ai_tools_close_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_close_ai_tools"
            android:tint="#9CA3AF" />
    </LinearLayout>

    <include layout="@layout/ai_writing_tools_content" />

</LinearLayout>
