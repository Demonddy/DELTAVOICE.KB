<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape: two-column layout - settings on left, actions/results on right -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="start"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Voice"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice input &amp; cloning"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Two-column content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left column: processing mode + language/voice settings -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Processing mode"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Mode cards: compact horizontal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:id="@+id/card_full"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/voice_mode_card_selected"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_lightning"
                            android:contentDescription="Full conversion"
                            android:tint="@color/voice_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/voice_mode_full"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:paddingTop="4dp"
                            android:gravity="center" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_voice_only"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/voice_mode_card_unselected"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_mic"
                            android:contentDescription="Voice only"
                            android:tint="@color/voice_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/voice_mode_voice_only"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:paddingTop="4dp"
                            android:gravity="center" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_text_only"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/voice_mode_card_unselected"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_text_t"
                            android:contentDescription="Text only"
                            android:tint="@color/voice_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/voice_mode_text_only"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:paddingTop="4dp"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Language & Voice selectors -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/voice_mode_pill_highlighted"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_globe"
                        android:tint="@color/voice_color" />

                    <Spinner
                        android:id="@+id/spinner_language"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:spinnerMode="dropdown"
                        android:popupBackground="#2A3140" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/voice_mode_pill_highlighted"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_speaker"
                        android:tint="@color/voice_color" />

                    <Spinner
                        android:id="@+id/spinner_voice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:spinnerMode="dropdown"
                        android:popupBackground="#2A3140" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- Right column: upload/record + results -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Record and process voice on this page."
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <Button
                        android:id="@+id/btn_upload_voice"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="  Upload"
                        android:drawableStart="@drawable/ic_upload"
                        android:drawablePadding="8dp"
                        android:background="@drawable/voice_mode_button_purple"
                        android:textColor="@color/text_primary"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp" />

                    <Button
                        android:id="@+id/btn_record_voice"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="  Record"
                        android:drawableStart="@drawable/ic_mic"
                        android:drawablePadding="8dp"
                        android:background="@drawable/voice_mode_button_purple"
                        android:textColor="@color/text_primary"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <!-- Recording / Processing section -->
                <LinearLayout
                    android:id="@+id/voice_recording_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_card_dark"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp">

                        <ImageButton
                            android:id="@+id/btn_play_recording"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_play"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Play"
                            android:tint="@color/voice_color" />

                        <TextView
                            android:id="@+id/recording_status"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Recording ready"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginStart="10dp" />

                        <TextView
                            android:id="@+id/audio_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_process_voice"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="  Process"
                        android:drawableStart="@drawable/ic_ai_mode"
                        android:drawablePadding="8dp"
                        android:background="@drawable/voice_mode_button_purple"
                        android:textColor="@color/text_primary"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/processed_voices_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Processed voices"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/processed_voice_view_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/btn_voice_view_list"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="List"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:background="@drawable/voice_mode_button_purple"
                            android:textColor="@color/text_primary" />

                        <Button
                            android:id="@+id/btn_voice_view_grid"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Grid"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:background="@drawable/bg_card_dark"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/processed_voices_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
