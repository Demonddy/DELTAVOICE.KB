<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme for the app (DayNight: light/dark based on setDefaultNightMode) -->
    <style name="Theme.DeltaVoice" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/surface_container_low</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:colorControlActivated">@color/accent</item>
        <!-- Ethereal: Manrope body (API 26+; older devices fall back to system sans) -->
        <item name="android:fontFamily">@font/manrope_regular</item>
    </style>

    <!-- Overlay bubble panels: MaterialComponents parent required for MaterialCardView and Material widgets in Service context -->
    <style name="Theme.DeltaVoice.Material" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/surface_container_low</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:colorControlActivated">@color/accent</item>
        <item name="android:fontFamily">@font/manrope_regular</item>
    </style>

    <!-- Headline style: Plus Jakarta Sans (use with android:textAppearance) -->
    <style name="TextAppearance.DeltaVoice.Headline" parent="TextAppearance.AppCompat.Title">
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
    </style>

    <!-- Full-screen app language picker (fixed dark, WhatsApp-like) -->
    <style name="Theme.DeltaVoice.AppLanguage" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/app_language_screen_bg</item>
        <item name="android:statusBarColor">@color/app_language_screen_bg</item>
        <item name="android:navigationBarColor">@color/app_language_screen_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">@font/manrope_regular</item>
    </style>

    <!-- Dialog theme: dark surface, accent buttons -->
    <style name="Theme.DeltaVoice.Dialog" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_dark</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:fontFamily">@font/manrope_regular</item>
    </style>

    <!-- Translucent theme for file-picker activities (VideoUpload, AudioUpload) -->
    <style name="Theme.DeltaVoice.Translucent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Liquid Glass IME: translucent + blur-ready (API 31+) -->
    <style name="Theme.DeltaVoice.IME" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
    </style>
</resources>
